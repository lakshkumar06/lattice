{
  "name": "stake-and-advance",
  "private": true,
  "type": "module",
  "scripts": {
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "cre:build": "cre workflow build ./cre",
    "cre:simulate": "cre workflow simulate ./cre --trigger-index 0 --http-payload ./cre/http-payload.json -T staging-settings -e ./.env",
    "cre:simulate:broadcast": "cre workflow simulate ./cre --broadcast --trigger-index 0 --http-payload ./cre/http-payload.json -T staging-settings -e ./.env",
    "cre:inference": "tsx server/inference.ts",
    "server:dev": "tsx server/index.ts",
    "keeper:auto-release": "tsx keeper/autoRelease.ts"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.6.0",
    "next": "^15.0.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0"
  }
}
