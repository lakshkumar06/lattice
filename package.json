{
  "name": "stake-and-advance",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "forge build --root contracts",
    "test": "forge test --root contracts",
    "test:v": "forge test --root contracts -vvv",
    "e2e:local": "bash scripts/e2e.local.sh",
    "server": "tsx server/index.ts",
    "server:local": "bash scripts/server.local.sh",
    "deploy:arc": "bash scripts/deploy.arc.sh",
    "keeper:mark-default": "tsx keeper/markDefault.ts",
    "cre:build": "cre workflow build ./cre",
    "cre:simulate": "cre workflow simulate ./cre --trigger-index 0 --http-payload ./cre/http-payload.json -T staging-settings -e ./.env",
    "cre:simulate:broadcast": "cre workflow simulate ./cre --broadcast --trigger-index 0 --http-payload ./cre/http-payload.json -T staging-settings -e ./.env"
  },
  "dependencies": {
    "@chainlink/cre-sdk": "^1.6.0",
    "next": "^15.0.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0"
  }
}
